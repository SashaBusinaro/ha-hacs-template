#!/usr/bin/env bash
#
# One-shot rename of every template placeholder. Run once after creating a new
# repository from the template, before your first commit.

set -e

cd "$(dirname "$0")/.."

if [[ ! -d "custom_components/integration_blueprint" ]]; then
    echo "Error: custom_components/integration_blueprint not found."
    echo "This template appears to be already bootstrapped — nothing to do."
    exit 1
fi

read -rp "Integration domain (lowercase, e.g. my_integration): " DOMAIN
read -rp "Integration display name (e.g. My Integration): " NAME
read -rp "GitHub username: " GH_USER
read -rp "GitHub repository name: " GH_REPO

if [[ -z "$DOMAIN" || -z "$NAME" || -z "$GH_USER" || -z "$GH_REPO" ]]; then
    echo "Error: all fields are required."
    exit 1
fi

if ! [[ "$DOMAIN" =~ ^[a-z][a-z0-9_]*$ ]]; then
    echo "Error: domain must start with a lowercase letter and contain only [a-z0-9_]."
    exit 1
fi

# BSD sed (macOS) needs an empty backup arg; GNU sed (Linux) does not.
if sed --version >/dev/null 2>&1; then
    SED_INPLACE=(sed -i)
else
    SED_INPLACE=(sed -i '')
fi

replace() {
    local from=$1 to=$2
    grep -rl --exclude-dir=.git --exclude="scripts/bootstrap" "$from" . 2>/dev/null \
        | xargs "${SED_INPLACE[@]}" "s|$from|$to|g" 2>/dev/null || true
}

echo "Rewriting placeholders..."
replace "integration_blueprint" "$DOMAIN"
replace "Integration blueprint" "$NAME"
replace "YOUR_INTEGRATION_NAME" "$NAME"
replace "YOUR_GITHUB_USERNAME" "$GH_USER"
replace "YOUR_REPO_NAME" "$GH_REPO"
replace "SashaBusinaro/ha-hacs-template" "$GH_USER/$GH_REPO"

mv custom_components/integration_blueprint "custom_components/$DOMAIN"

echo
echo "Done. Next steps:"
echo "  1. Review the diff:           git diff && git status"
echo "  2. Install pre-commit hooks:  pip install pre-commit && pre-commit install"
echo "  3. Stage and commit:          git add -A && git commit -m 'chore: bootstrap from template'"
echo "     (pre-commit runs automatically on the staged files at commit time)"
